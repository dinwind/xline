{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "agent-protocol",
  "version": "3.3.0",
  "description": "AI Agent Collaboration Protocol - Standardized Digital Asset",
  "directory_name": ".agent",
  "directory_name_comment": "Protocol directory name, documents use $AGENT_DIR placeholder",
  "loading_strategy": {
    "layers": {
      "essential": {
        "description": "Core required files, must load every session",
        "load": "always",
        "token_budget": 3000,
        "files": [
          "project/status.md",
          "start-here.md",
          "core/core-rules.md"
        ]
      },
      "context": {
        "description": "Project context, load at session start",
        "load": "session_start",
        "token_budget": 2000,
        "files": [
          "core/instructions.md",
          "project/context.md",
          "project/tech-stack.md",
          "project/known-issues.md",
          "project/deploy.md",
          "project/commands.md"
        ]
      },
      "stack_specs": {
        "description": "Tech stack specs, load based on project stack",
        "load": "on_demand",
        "selector": "project.primary_stack",
        "options": {
          "python": [
            "core/stack-specs/python.md"
          ],
          "rust": [
            "core/stack-specs/rust.md"
          ],
          "qt": [
            "core/stack-specs/qt.md"
          ],
          "mixed": [
            "core/stack-specs/python.md",
            "core/stack-specs/rust.md"
          ]
        }
      },
      "workflows": {
        "description": "Workflow specs, load by task type",
        "load": "on_demand",
        "trigger": "task_type",
        "mappings": {
          "coding": [
            "core/workflows/bug-prevention.md",
            "core/workflows/design-principles.md",
            "core/workflows/adr-guide.md"
          ],
          "testing": [
            "core/workflows/testing.md"
          ],
          "documentation": [
            "core/workflows/documentation.md"
          ],
          "review": [
            "core/workflows/review-process.md",
            "core/workflows/quality-assurance.md",
            "project/sop/code-review.md"
          ],
          "design_review": [
            "core/workflows/design-principles.md",
            "core/workflows/review-process.md"
          ],
          "planning": [
            "core/workflows/pre-task-checklist.md",
            "core/workflows/ai-boundaries.md",
            "core/workflows/token-budget.md"
          ],
          "ui": [
            "core/workflows/ui-design-workflow.md"
          ],
          "research": [
            "core/workflows/research-workflow.md"
          ],
          "versioning": [
            "core/workflows/version-governance-workflow.md",
            "project/versioning.md",
            "project/version-state.toml",
            "project/sop/release.md"
          ],
          "release_docs": [
            "core/workflows/release-doc-refresh-workflow.md",
            "core/workflows/version-governance-workflow.md",
            "project/sop/release-doc-refresh.md",
            "project/versioning.md",
            "project/version-state.toml"
          ],
          "docker": [
            "core/workflows/docker-build-optimization.md"
          ],
          "policy": [
            "core/workflows/policy-as-code.md"
          ],
          "git": [
            "project/AGENT-GIT-PR-WORKFLOW.md",
            "project/sop/agent-git-pr-collaboration.md",
            "project/sop/git-workflow.md"
          ]
        }
      },
      "skills": {
        "description": "Skill modules, load on demand",
        "load": "on_demand",
        "trigger": "skill_request",
        "modules": {
          "interface": {
            "entry": "skills/skill-interface.md",
            "description": "Skill development interface spec"
          },
          "guardian": {
            "entry": "skills/guardian/SKILL.md",
            "description": "Code/doc quality check"
          },
          "ai-integration": {
            "entry": "skills/ai-integration/llm-client.md",
            "files": [
              "skills/ai-integration/llm-client.md",
              "skills/ai-integration/prompt-engineering.md",
              "skills/ai-integration/domain-adaptation.md"
            ],
            "description": "AI/LLM integration development"
          },
          "agent-governance": {
            "entry": "skills/agent-governance/SKILL.md",
            "description": "Protocol health check"
          }
        }
      },
      "reference": {
        "description": "Reference docs, load when consulting",
        "load": "on_demand",
        "files": [
          "core/conventions.md",
          "core/stack-specs/git.md",
          "core/security.md",
          "core/examples.md",
          "meta/protocol-adr.md",
          "project/conventions.md"
        ]
      }
    },
    "task_profiles": {
      "code_review": {
        "description": "Code review task",
        "layers": [
          "essential",
          "context",
          "stack_specs"
        ],
        "workflows": [
          "review"
        ],
        "skills": [
          "guardian"
        ]
      },
      "design_review": {
        "description": "Design / architecture / requirements review task",
        "layers": [
          "essential",
          "context"
        ],
        "workflows": [
          "design_review"
        ],
        "skills": []
      },
      "feature_development": {
        "description": "Feature development task",
        "layers": [
          "essential",
          "context",
          "stack_specs"
        ],
        "workflows": [
          "coding",
          "testing"
        ],
        "skills": []
      },
      "bug_fix": {
        "description": "Bug fix task",
        "layers": [
          "essential",
          "context",
          "stack_specs"
        ],
        "workflows": [
          "coding"
        ],
        "skills": [
          "guardian"
        ]
      },
      "documentation": {
        "description": "Documentation task",
        "layers": [
          "essential",
          "context"
        ],
        "workflows": [
          "documentation"
        ],
        "skills": []
      },
      "ai_integration": {
        "description": "AI integration development task",
        "layers": [
          "essential",
          "context",
          "stack_specs"
        ],
        "workflows": [
          "coding",
          "testing"
        ],
        "skills": [
          "ai-integration"
        ]
      },
      "research": {
        "description": "Research task (industry/market survey, technology comparison, feasibility)",
        "layers": [
          "essential",
          "context"
        ],
        "workflows": [
          "research"
        ],
        "skills": []
      },
      "release": {
        "description": "Release / version governance task",
        "layers": [
          "essential",
          "context"
        ],
        "workflows": [
          "versioning"
        ],
        "skills": []
      },
      "versioning": {
        "description": "Version policy / state / release governance task",
        "layers": [
          "essential",
          "context"
        ],
        "workflows": [
          "versioning"
        ],
        "skills": []
      }
    }
  },
  "required_files": [
    "start-here.md",
    "index.md",
    "core/core-rules.md",
    "core/instructions.md",
    "core/conventions.md",
    "project/status.md",
    "project/context.md",
    "project/tech-stack.md",
    "project/deploy.md",
    "meta/protocol-adr.md"
  ],
  "naming_conventions": {
    "markdown_files": "^[a-z0-9]+(-[a-z0-9]+)*\\.md$",
    "directories": "^[a-z0-9]+(-[a-z0-9]+)*$",
    "exceptions": [
      "MANIFEST.json",
      "VERSION",
      "SKILL.md"
    ]
  },
  "compatibility": {
    "min_version": "3.0.0",
    "breaking_changes": [
      {
        "version": "2.0.0",
        "description": "Protocol unified merge, directory structure changed"
      }
    ],
    "minor_changes": [
      {
        "version": "3.3.0",
        "description": "Policy-as-code workflow and bundled OPA/Conftest policies (release.rego, release_note.rego); pre-commit policy hook template; design_review workflow surfaced; project SOP code-review.md template promoted to required SOP"
      },
      {
        "version": "3.2.9",
        "description": "Registered MCP template tools `list_templates` and `get_template` for bundled protocol and CI adapter template discovery"
      },
      {
        "version": "3.2.8",
        "description": "Added version-governance CI/CD and release-automation examples to project templates, CI adapter guidance, and usage docs"
      },
      {
        "version": "3.2.7",
        "description": "Added `co cut-release` helper to finalize released track state after canonical-source and release checks"
      },
      {
        "version": "3.2.6",
        "description": "Added `co prepare-release` helper for explicit release-freeze state transition before cut-release"
      },
      {
        "version": "3.2.5",
        "description": "Added `co start-next-version` helper for explicit next-iteration state transition and release-note draft initialization"
      },
      {
        "version": "3.2.4",
        "description": "Generic version-state checker/lint rule for structured version governance: schema, track state, canonical source, release note, tag, and rollback validation"
      },
      {
        "version": "3.2.3",
        "description": "Version governance workflow and release/versioning task profiles: version-governance-workflow.md, version-state template, track-based release SOP"
      },
      {
        "version": "3.2.2",
        "description": "Research workflow and task profile: research-workflow.md, citation record and credibility assessment; start-here and MCP task=research"
      },
      {
        "version": "3.2.1",
        "description": "SDD active change in session init: instructions.md and start-here; status template placeholder; IDE adapters mention tasks.md when Active change (SDD) set"
      },
      {
        "version": "3.2.0",
        "description": "Added project/status.md for session continuity; status.md in essential loading layer; session maintenance rule in instructions.md; ADR 008"
      },
      {
        "version": "3.1.0",
        "description": "Added deploy.md, conventions.md templates; ADR guide workflow; skill parameterization; token budget guide"
      }
    ],
    "patch_changes": [
      {
        "version": "3.1.1",
        "description": "Scope clarity (UTF-8/emoji apply to entire project); no-emoji in core; protocol self-check prompt in meta/; ADR 005 (UTF-8 consolidation), ADR 006 (scope and emoji audit)"
      }
    ]
  },
  "metadata": {
    "created": "2026-01-23",
    "updated": "2026-04-22",
    "maintainer": "AI Agent Protocol Team"
  },
